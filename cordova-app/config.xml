<?xml version='1.0' encoding='utf-8'?>
<widget id="com.prudentmf.rmapp" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>Prudent MF RM</name>
    <description>
        Relationship Manager app for Prudent MF Distribution Team
    </description>
    <author email="support@prudentmf.com" href="https://prudentmf.com">
        Prudent MF Team
    </author>
    <content src="index.html" />
    <access origin="*" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <allow-intent href="tel:*" />
    <allow-intent href="sms:*" />
    <allow-intent href="mailto:*" />
    <allow-intent href="geo:*" />
    
    <platform name="android">
        <allow-intent href="market:*" />
        <preference name="android-minSdkVersion" value="24" />
        <preference name="android-targetSdkVersion" value="33" />
        <icon density="ldpi" src="www/assets/logo.png" />
        <icon density="mdpi" src="www/assets/logo.png" />
        <icon density="hdpi" src="www/assets/logo.png" />
        <icon density="xhdpi" src="www/assets/logo.png" />
        <icon density="xxhdpi" src="www/assets/logo.png" />
        <icon density="xxxhdpi" src="www/assets/logo.png" />
    </platform>
    
    <preference name="DisallowOverscroll" value="true" />
    <preference name="Orientation" value="portrait" />
    <preference name="Fullscreen" value="false" />
    <preference name="StatusBarOverlaysWebView" value="false" />
    <preference name="StatusBarBackgroundColor" value="#0B1F3A" />
    <preference name="StatusBarStyle" value="lightcontent" />
</widget>